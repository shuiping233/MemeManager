<Page
    x:Class="MemeManager.SettingsPage"
    Loaded="SettingsPage_Loaded"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MemeManager"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" HorizontalAlignment="Left">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="设置" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1" Spacing="16" MaxWidth="400">
            <StackPanel Spacing="6">
                <TextBlock Text="主题" FontWeight="SemiBold"/>
                <ComboBox x:Name="ThemeComboBox" Width="125" SelectionChanged="ThemeComboBox_SelectionChanged">
                    <x:String>跟随系统</x:String>
                    <x:String>浅色</x:String>
                    <x:String>深色</x:String>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="表情包存放路径" FontWeight="SemiBold"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="StoragePathBox" Grid.Column="0" IsReadOnly="False" VerticalAlignment="Center" MaxWidth="200" TextChanged="StoragePathBox_TextChanged"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0" Spacing="4">
                        <Button x:Name="BrowseButton" Content="浏览..." Click="BrowseButton_Click"/>
                        <Button x:Name="OpenFolderButton" Content="打开存放文件夹" Click="OpenFolderButton_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="呼出快捷键" FontWeight="SemiBold"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="HotKeyBox" Grid.Column="0" IsReadOnly="True"
                             VerticalAlignment="Center" Text="Alt+E"/>
                    <Button x:Name="RecordHotKeyButton" Grid.Column="1" Content="录制..."
                            Margin="8,0,0,0" Click="RecordHotKeyButton_Click"/>
                </Grid>
                <TextBlock FontSize="11" Opacity="0.6">点击“录制”后，按下想要的组合键（如 Alt+E）</TextBlock>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="保存日志文件" FontWeight="SemiBold"/>
                <ToggleSwitch x:Name="SaveLogToggle" Toggled="SaveLogToggle_Toggled"/>
                <TextBlock FontSize="11" Opacity="0.6">日志位于数据目录的 log 文件夹下，一般无需启用，5MB自动清理</TextBlock>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="开机自动启动" FontWeight="SemiBold"/>
                <ToggleSwitch x:Name="AutoStartToggle" Toggled="AutoStartToggle_Toggled"/>
                <TextBlock FontSize="11" Opacity="0.6">登录系统后自动在后台运行（仅托盘，不弹主窗口）</TextBlock>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="拖出图片时以图片格式输出" FontWeight="SemiBold"/>
                <ToggleSwitch x:Name="DragOutputAsImageToggle" Toggled="DragOutputAsImageToggle_Toggled"/>
                <TextBlock FontSize="11" Opacity="0.6" TextWrapping="Wrap">启用后, 拖出单张图片时额外转换成图片格式, 兼容老版本 QQ</TextBlock>
                <TextBlock FontSize="11" Opacity="0.6" TextWrapping="Wrap">受系统剪贴板格式限制, 仅拖出单张时生效; 一次拖出多张仍以文件形式发送</TextBlock>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="启用控件复用策略" FontWeight="SemiBold"/>
                <ToggleSwitch x:Name="UseControlReuseToggle" Toggled="UseControlReuseToggle_Toggled"/>
                <TextBlock FontSize="11" Opacity="0.6" TextWrapping="Wrap">启用后, 图片控件将尽可能的少创建而是复用, 以减少创建图片控件的内存消耗, 会影响 刷新/切换分支/开关窗口 时的行为</TextBlock>
                <TextBlock FontSize="11" Opacity="0.6" TextWrapping="Wrap">此功能会导致关闭主窗口后后台仍保留图片缓存（WinUI3局限所致）</TextBlock>
                <TextBlock FontSize="11" Opacity="0.6" TextWrapping="Wrap">且后台进程专用工作集会有几十MB的图片缓存内容常驻不会释放</TextBlock>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="预览图最大分辨率" FontWeight="SemiBold"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="宽" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="PreviewMaxWidthBox" Grid.Column="1" Width="80"
                             InputScope="Number" BeforeTextChanging="PreviewNumberBox_BeforeTextChanging" TextChanged="PreviewResolution_TextChanged"/>
                    <TextBlock Grid.Column="2" Text="高" VerticalAlignment="Center" Margin="12,0,6,0"/>
                    <TextBox x:Name="PreviewMaxHeightBox" Grid.Column="3" Width="80"
                             InputScope="Number" BeforeTextChanging="PreviewNumberBox_BeforeTextChanging" TextChanged="PreviewResolution_TextChanged"/>
                </Grid>
                <TextBlock FontSize="11" Opacity="0.6">超过该尺寸的预览图将等比压缩，未超过则不缩放 (默认 640*480）</TextBlock>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="预览图触发延时（毫秒）" FontWeight="SemiBold"/>
                <TextBox x:Name="PreviewDelayBox" Width="80" HorizontalAlignment="Left"
                         InputScope="Number" BeforeTextChanging="PreviewNumberBox_BeforeTextChanging" TextChanged="PreviewDelay_TextChanged"/>
                <TextBlock FontSize="11" Opacity="0.6">鼠标悬停后等待多久才弹出预览（默认 500）</TextBlock>
            </StackPanel>
        </StackPanel>

        <Button Grid.Row="2" x:Name="CloseButton" Content="完成" HorizontalAlignment="Right"
                Margin="0,16,0,0" Click="CloseButton_Click"
                Style="{StaticResource AccentButtonStyle}"/>
    </Grid>
</Page>
