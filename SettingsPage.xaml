<Page
    x:Class="MemeManager.SettingsPage"
    Loaded="SettingsPage_Loaded"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MemeManager"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" HorizontalAlignment="Left">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="设置" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1" Spacing="16" MaxWidth="600">
            <StackPanel Spacing="6">
                <TextBlock Text="主题" FontWeight="SemiBold"/>
                <ComboBox x:Name="ThemeComboBox" Width="125" SelectionChanged="ThemeComboBox_SelectionChanged">
                    <x:String>跟随系统</x:String>
                    <x:String>浅色</x:String>
                    <x:String>深色</x:String>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="表情包存放路径" FontWeight="SemiBold"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="StoragePathBox" Grid.Column="0" IsReadOnly="False" VerticalAlignment="Center" MaxWidth="200" TextChanged="StoragePathBox_TextChanged"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0" Spacing="4">
                        <Button x:Name="BrowseButton" Content="浏览..." Click="BrowseButton_Click"/>
                        <Button x:Name="OpenFolderButton" Content="打开存放文件夹" Click="OpenFolderButton_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="呼出快捷键" FontWeight="SemiBold"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="HotKeyBox" Grid.Column="0" IsReadOnly="True"
                             VerticalAlignment="Center" Text="Alt+E"/>
                    <Button x:Name="RecordHotKeyButton" Grid.Column="1" Content="录制..."
                            Margin="8,0,0,0" Click="RecordHotKeyButton_Click"/>
                </Grid>
                <TextBlock FontSize="11" Opacity="0.6">点击“录制”后，按下想要的组合键（如 Alt+E）</TextBlock>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="保存日志文件" FontWeight="SemiBold"/>
                <ToggleSwitch x:Name="SaveLogToggle" Toggled="SaveLogToggle_Toggled"/>
                <TextBlock FontSize="11" Opacity="0.6">日志位于数据目录的 log 文件夹下，一般无需启用，5MB自动清理</TextBlock>
            </StackPanel>
        </StackPanel>

        <Button Grid.Row="2" x:Name="CloseButton" Content="完成" HorizontalAlignment="Right"
                Margin="0,16,0,0" Click="CloseButton_Click" Style="{StaticResource AccentButtonStyle}"/>
    </Grid>
</Page>
